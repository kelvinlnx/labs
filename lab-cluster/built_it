## Monitoring & Grafana
#helm repo add prometheus-community https://prometheus-community.github.io/helm-charts
#helm repo update
#helm install monitoring prometheus-community/kube-prometheus-stack --namespace monitoring --create-namespace

# Alias k
if `grep -q 'alias k=' ~/.bash_aliases 2> /dev/null`; then
	echo alias k already configured
else
cat << EOF >> ~/.bash_aliases
source <(kubectl completion bash)
alias k=kubectl
complete -o default -F __start_kubectl k
EOF
fi

echo "📁 Creating Image Registry namespace..."
kubectl create ns ${REGISTRY_NAMESPACE}

echo "🔑 Creating TLS secret for registry..."
kubectl create secret tls registry-tls \
  --cert=${CERTS_DIR}/registry.crt \
  --key=${CERTS_DIR}/registry.key \
  -n ${REGISTRY_NAMESPACE}

echo "📦 Deploying registry..."
cat << EOF > image-registry.yaml
apiVersion: v1
kind: Service
metadata:
  name: docker-registry
  namespace: ${REGISTRY_NAMESPACE}
spec:
  selector:
    app: docker-registry
  ports:
    - protocol: TCP
      port: 5000
      targetPort: 5000
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: docker-registry
  namespace: ${REGISTRY_NAMESPACE}
spec:
  replicas: 1
  selector:
    matchLabels:
      app: docker-registry
  template:
    metadata:
      labels:
        app: docker-registry
    spec:
      nodeSelector:
        image-registry: "true"
      containers:
      - name: registry
        image: registry:2
        ports:
        - containerPort: 5000
          hostPort: 5000     # this binds to host port
        env:
        - name: REGISTRY_HTTP_TLS_CERTIFICATE
          value: /certs/tls.crt
        - name: REGISTRY_HTTP_TLS_KEY
          value: /certs/tls.key
        volumeMounts:
        - name: registry-data
          mountPath: /var/lib/registry
        - name: certs
          mountPath: /certs
          readOnly: true
      volumes:
      - name: registry-data
        emptyDir: {} # Use a PVC here for production-like persistence
      - name: certs
        secret:
          secretName: registry-tls
EOF
kubectl apply -f image-registry.yaml

echo "⏳ Waiting for registry pod to be ready..."
kubectl wait --for=condition=ready pod -l app=docker-registry -n ${REGISTRY_NAMESPACE} --timeout=60s

echo "🧪 Testing secure connection..."
kubectl run test-pod --rm -it --image=curlimages/curl --restart=Never --restart=Never -- \
  curl -k https://docker-registry.${REGISTRY_NAMESPACE}.svc.cluster.local:5000/v2/ || \
  echo "⚠️  Test failed, but registry should still be working"

echo "✅ Registry setup complete!"
echo "📍 Registry URL: https://docker-registry.${REGISTRY_NAMESPACE}.svc.cluster.local:5000"

# Cleanup
# echo "🧺 Cleanup..."
# rm -rf $CERTS_DIR *yaml
