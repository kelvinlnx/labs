#!/bin/bash


CLUSTER_NAME="lab"
REGISTRY_NAMESPACE="image-registry"
REGISTRY_DOMAIN="docker-registry.${REGISTRY_NAMESPACE}.svc.cluster.local"
CERTS_DIR="certs"
REGISTRY_HOST="myregistry"

echo "🔧 Generating certificates for ${REGISTRY_DOMAIN}..."
mkdir $CERTS_DIR
cd $CERTS_DIR

# Generate CA key and certificate
openssl req -new -newkey rsa:2048 -days 365 -nodes -x509 \
  -subj "/C=SG/ST=Sg/L=Sg/O=Training/CN=Training CA" \
  -keyout ca.key -out ca.crt 2>/dev/null

# Generate registry key
openssl genrsa -out registry.key 2048 2>/dev/null

# Create CSR config
cat > registry.conf <<EOF
[req]
distinguished_name = req_distinguished_name
req_extensions = v3_req
prompt = no

[req_distinguished_name]
C = SG
ST = Sg
L = Sg
O = Training
CN = ${REGISTRY_DOMAIN}

[v3_req]
keyUsage = keyEncipherment, dataEncipherment
extendedKeyUsage = serverAuth
subjectAltName = @alt_names

[alt_names]
DNS.1 = ${REGISTRY_DOMAIN}
DNS.2 = docker-registry.${NAMESPACE}
DNS.3 = docker-registry.${NAMESPACE}.svc
DNS.4 = ${REGISTRY_HOST}
EOF

# Generate CSR
openssl req -new -key registry.key -out registry.csr -config registry.conf 2>/dev/null

# Sign certificate with CA
openssl x509 -req -days 365 -in registry.csr \
  -CA ca.crt -CAkey ca.key -CAcreateserial \
  -out registry.crt -extensions v3_req -extfile registry.conf 2>/dev/null

cd ..

echo "🖧  Preparing NFS storage /srv/nfs-data... "
# Prepare nfs directory for storage class
sudo mkdir /srv/nfs-data
sudo chmod 777 /srv/nfs-data
sudo chown nobody:nogroup /srv/nfs-data

# create the kind-config.yaml file
cat <<EOF > kind-config.yaml
kind: Cluster
apiVersion: kind.x-k8s.io/v1alpha4
name: ${CLUSTER_NAME}
networking:
  apiServerAddress: "127.0.0.1"
  apiServerPort: 6443
nodes:
# 1. The Control Plane (NFS Server + API)
- role: control-plane
  extraMounts:
    # Persist the NFS share directory
  - hostPath: /srv/nfs-data
    containerPath: /nfsshare
  - hostPath: ${CERTS_DIR}/ca.crt
    containerPath: /usr/local/share/ca-certificates/registry-ca.crt

# 2. Worker 1: The "Edge" Node (Ingress + Registry)
- role: worker
  kubeadmConfigPatches:
  - |
    kind: JoinConfiguration
    nodeRegistration:
      kubeletExtraArgs:
        node-labels: "ingress-ready=true,image-registry=true"
  extraPortMappings:
  - containerPort: 80
    hostPort: 80
  - containerPort: 443
    hostPort: 443
  - containerPort: 5000
    hostPort: 5000
  extraMounts:
  - hostPath: ${CERTS_DIR}/ca.crt
    containerPath: /usr/local/share/ca-certificates/registry-ca.crt

# 3. Worker 2: The "Data" Node (Prometheus + EFK)
- role: worker
  kubeadmConfigPatches:
  - |
    kind: JoinConfiguration
    nodeRegistration:
      kubeletExtraArgs:
        node-labels: "tier=backend"
  extraMounts:
  - hostPath: ${CERTS_DIR}/ca.crt
    containerPath: /usr/local/share/ca-certificates/registry-ca.crt
containerdConfigPatches:
- |-
  [plugins."io.containerd.grpc.v1.cri".registry]
    config_path = "/etc/containerd/certs.d"
EOF

echo "🚀 Creating Kind cluster..."
kind delete cluster --name ${CLUSTER_NAME} 2>/dev/null || true
kind create cluster --config kind-config.yaml

echo "🔐 Updating Packages & CA certificates on nodes..."
docker exec -it lab-control-plane bash -c "apt update; apt install -y nfs-kernel-server; echo '/nfsshare *(rw,sync,no_subtree_check,no_root_squash,insecure)' >> /etc/exports; systemctl enable --now nfs-server; update-ca-certificates"
docker exec -it lab-worker bash -c "apt update; apt install -y nfs-common; update-ca-certificates"
docker exec -it lab-worker2 bash -c "apt update; apt install -y nfs-common; update-ca-certificates"
sudo cp ${CERTS_DIR}/ca.crt /usr/local/share/ca-certificates/registry-ca.crt
sudo update-ca-certificates

# Create ingress controller(nginx)
kubectl apply -f https://raw.githubusercontent.com/kubernetes/ingress-nginx/main/deploy/static/provider/kind/deploy.yaml
kubectl patch deployment -n ingress-nginx ingress-nginx-controller -p '{"spec":{"template":{"spec":{"nodeSelector":{"ingress-ready":"true"}}}}}'

## Metrics
